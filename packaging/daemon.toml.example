# Control-OFC Daemon — admin-owned configuration.
# Copy to /etc/control-ofc/daemon.toml and edit as needed.
# All fields are optional — defaults are shown below.
#
# NOTE: runtime-mutable settings (profile search directories, startup delay)
# are stored separately in /var/lib/control-ofc/runtime.toml, which the
# daemon manages itself via the API. This file is admin-owned and is never
# rewritten by the daemon at runtime. See docs/ADRs/002-runtime-config-split.md.

[serial]
# Use stable /dev/serial/by-id/ path (survives USB re-enumeration)
# port = "/dev/serial/by-id/usb-Karanovic_Research_OpenFan_...-if00"
# timeout_ms = 500

[polling]
# poll_interval_ms = 1000

[ipc]
# socket_path = "/run/control-ofc/control-ofc.sock"

[state]
# state_dir = "/var/lib/control-ofc"
