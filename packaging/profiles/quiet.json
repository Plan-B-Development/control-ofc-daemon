{
  "id": "quiet",
  "name": "Quiet (example)",
  "version": 3,
  "description": "Example profile shipped with control-ofc-daemon. Drives no fans as-is — the `members` list is intentionally empty so a fresh install is safe. Copy this file, add your fan members, and point at it via the GUI or /profile/activate.",
  "controls": [
    {
      "id": "example_group",
      "name": "Example group",
      "mode": "curve",
      "curve_id": "quiet_curve",
      "manual_output_pct": 50.0,
      "members": [],
      "step_up_pct": 100.0,
      "step_down_pct": 100.0,
      "offset_pct": 0.0,
      "minimum_pct": 0.0,
      "start_pct": 0.0,
      "stop_pct": 0.0
    }
  ],
  "curves": [
    {
      "id": "quiet_curve",
      "name": "Quiet curve",
      "type": "graph",
      "sensor_id": "",
      "points": [
        { "temp_c": 30.0, "output_pct": 25.0 },
        { "temp_c": 45.0, "output_pct": 35.0 },
        { "temp_c": 60.0, "output_pct": 45.0 },
        { "temp_c": 75.0, "output_pct": 60.0 },
        { "temp_c": 85.0, "output_pct": 80.0 }
      ]
    }
  ]
}
