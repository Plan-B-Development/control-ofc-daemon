[Unit]
Description=Control-OFC Fan Control Daemon
After=local-fs.target
# Ensure cdc_acm is loaded before we start so that DeviceAllow=char-ttyACM
# can resolve the device group from /proc/devices. Without this, starting
# before cdc_acm loads (common on boot, before USB enumeration) leaves the
# cgroup filter without a ttyACM rule, and the daemon gets EPERM when the
# OpenFanController appears shortly after. See systemd.resource-control(5).
Wants=modprobe@cdc_acm.service
After=modprobe@cdc_acm.service

[Service]
Type=simple
ExecStart=/usr/bin/control-ofc-daemon
ExecStopPost=/usr/bin/control-ofc-restore-auto
ExecReload=/bin/kill -HUP $MAINPID
RuntimeDirectory=control-ofc
StateDirectory=control-ofc
# Socket: /run/control-ofc/control-ofc.sock (created by daemon)
# State: /var/lib/control-ofc/daemon_state.json (active profile pointer)
# Override config: /etc/control-ofc/daemon.toml

# Logging goes to journald by default (env_logger → stderr → journald)
Environment=RUST_LOG=info
# HOME is required for default profile search dirs (~/.config/control-ofc/profiles).
# systemd does not set HOME when no User= is specified (systemd.exec(5)).
Environment=HOME=/root

# Restart on crash
Restart=on-failure
RestartSec=3

# Privilege model: daemon runs as root (no User= directive).
# Root is required for direct read/write to /sys/class/hwmon and /sys/class/drm
# sysfs nodes (motherboard fan PWM headers and GPU PMFW fan curves). Serial
# device access (/dev/ttyACM*) is handled via DeviceAllow below.
# CapabilityBoundingSet is intentionally omitted: with NoNewPrivileges=true and
# SystemCallFilter active, child-process capability escalation is already blocked.
# Adding CapabilityBoundingSet provides marginal additional protection for a root
# process and risks breaking sysfs writes if the wrong cap is dropped. Revisit
# post-release with per-capability verification on real hardware.

# Security hardening
ProtectHome=read-only
ProtectSystem=strict
# /sys/class/hwmon is directory-level — hwmon indices are dynamic, finer restriction not practical (P2-S3).
# /run/control-ofc and /var/lib/control-ofc are provided by RuntimeDirectory= and StateDirectory=
# above; systemd.exec(5) guarantees those are already writable under ProtectSystem=strict, so only
# /sys paths need an explicit entry here.
ReadWritePaths=/sys/class/hwmon /sys/class/drm
PrivateTmp=true
NoNewPrivileges=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectKernelLogs=true
ProtectControlGroups=true
RestrictNamespaces=true
RestrictRealtime=true
RestrictSUIDSGID=true
LockPersonality=true
MemoryDenyWriteExecute=true
SystemCallFilter=@system-service
SystemCallFilter=~@mount @reboot @swap @debug

# Serial device access (OpenFanController)
# Allow all ttyACM and ttyUSB devices (index varies across systems)
DeviceAllow=char-usb_device rwm
DeviceAllow=char-ttyACM rwm
DeviceAllow=char-ttyUSB rwm
# uucp (Arch/CachyOS) — dialout (Debian/Ubuntu) omitted; systemd fails on missing groups
SupplementaryGroups=uucp

[Install]
WantedBy=multi-user.target
